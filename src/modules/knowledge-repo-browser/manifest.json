{
  "id": "knowledge-repo-browser",
  "name": "Repo Browser",
  "version": "1.0.0",
  "type": "knowledge",
  "description": "Browses the repository.",
  "tools": [
    {
      "name": "knowledge-repo-browser.listFiles",
      "description": "List files in a repository path.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "The path to list files from." }
        }
      }
    },
    {
      "name": "knowledge-repo-browser.readFile",
      "description": "Read the content of a file in a repository.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "The file path." }
        },
        "required": ["path"]
      }
    },
    {
      "name": "knowledge-repo-browser.headFile",
      "description": "Read the first N lines of a file in a repository.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "The file path." },
          "lines": { "type": "number", "description": "The number of lines to read. Default is 3." }
        },
        "required": ["path"]
      }
    },
    {
      "name": "knowledge-repo-browser.writeFile",
      "description": "Write content to a file in the repository. Creates a new commit.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "The file path." },
          "content": { "type": "string", "description": "The content to write." },
          "commitMessage": { "type": "string", "description": "The commit message." }
        },
        "required": ["path", "content"]
      }
    }
  ],
  "sandboxBindings": {
    "repo.listFiles": "knowledge-repo-browser.listFiles",
    "repo.readFile": "knowledge-repo-browser.readFile",
    "repo.headFile": "knowledge-repo-browser.headFile",
    "repo.writeFile": "knowledge-repo-browser.writeFile"
  },
  "permissions": ["github-api"],
  "configFields": [
    { "key": "repoUrl", "type": "string", "label": "Repository URL", "description": "Repository URL (owner/repo)", "required": true },
    { "key": "repoBranch", "type": "string", "label": "Repository Branch", "description": "Repository Branch", "required": false, "default": "main" }
  ]
}
