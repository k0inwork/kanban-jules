{
  "id": "architect-codegen",
  "name": "Architect Codegen",
  "version": "1.0.0",
  "type": "executor",
  "description": "Generates task protocols and architectural plans.",
  "tools": [
    {
      "name": "architect-codegen.generateProtocol",
      "description": "Generate a task protocol based on task title and description.",
      "parameters": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  ],
  "sandboxBindings": {
    "generateProtocol": "architect-codegen.generateProtocol"
  },
  "permissions": ["llm"],
  "configFields": [
    { "name": "geminiApiKey", "type": "string", "description": "Gemini API Key" }
  ]
}
