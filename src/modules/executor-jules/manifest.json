{
  "id": "executor-jules",
  "name": "Google Jules",
  "version": "1.0.0",
  "type": "executor",
  "description": "Fully autonomous coding agent in a cloud VM. Give it large ambitious tasks.",
  "tools": [
    {
      "name": "executor-jules.execute",
      "description": "Steering loop: send to Jules, poll, verify, feed back, repeat.",
      "parameters": { "type": "object", "properties": { "prompt": { "type": "string" }, "successCriteria": { "type": "string" } } }
    }
  ],
  "sandboxBindings": {
    "askJules": "executor-jules.execute"
  },
  "permissions": ["network", "jules-api"],
  "configFields": [
    { "name": "julesApiKey", "type": "string", "description": "Google Jules API Key" },
    { "name": "julesDailyLimit", "type": "number", "description": "Daily task limit" },
    { "name": "julesConcurrentLimit", "type": "number", "description": "Concurrent task limit" }
  ]
}
