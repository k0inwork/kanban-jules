#!/bin/busybox sh
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts 2>/dev/null
mount -t binfmt_misc none /proc/sys/fs/binfmt_misc
echo ':wasm:M::\x00\x61\x73\x6d::/bin/wexec:' > /proc/sys/fs/binfmt_misc/register

source /etc/profile
ifconfig lo up
ifconfig eth0 up
udhcpc -i eth0

# Board tools available in PATH
export PATH=$PATH:/board/bin

# Terminal settings for dvtm/ncurses
export TERM=xterm

# Read terminal size from /etc/term-size if set by boot.wasm, else defaults
if [ -f /etc/term-size ]; then
    export COLUMNS=$(awk -F= '/^cols/ {print $2}' /etc/term-size)
    export LINES=$(awk -F= '/^rows/ {print $2}' /etc/term-size)
fi
: ${COLUMNS:=100}
: ${LINES:=30}

exec setsid /bin/session-mux </dev/ttyS0 >/dev/ttyS0 2>&1
